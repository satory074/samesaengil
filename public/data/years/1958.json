{"year":1958,"events":[{"month":1,"day":1,"text":"2つのローマ条約の発効により、欧州経済共同体と欧州原子力共同体が設立される。"},{"month":1,"day":3,"text":"西インド連邦結成。"},{"month":1,"day":4,"text":"スプートニク1号が大気圏に再突入し消滅（1957年10月4日打ち上げ）。"},{"month":1,"day":11,"text":"韓国進歩党事件。"},{"month":1,"day":15,"text":"東京都の学校給食に牛乳が加わる。"},{"month":1,"day":20,"text":"大日本製薬がサリドマイドを配合した「イソミン」を発売（後にサリドマイド訴訟に発展した）。"},{"month":1,"day":26,"text":"南海丸遭難事故。"},{"month":1,"day":28,"text":"がレゴブロックを特許申請。"},{"month":1,"day":31,"text":"アメリカ初の人工衛星、エクスプローラー1号打ち上げ。"},{"month":1,"day":31,"text":"ジェームズ・ヴァン・アレンによるヴァン・アレン帯の発見。"},{"month":2,"day":1,"text":"エジプト共和国とシリア共和国が合併し、アラブ連合共和国が建国。"},{"month":2,"day":1,"text":"神戸市が兵庫県美嚢郡淡河村を編入（兵庫区となり、1973年から神戸市北区へ分区）。"},{"month":2,"day":6,"text":"ミュンヘンの悲劇。マンチェスター・ユナイテッドFCの選手8人を含む乗客23人が死亡。"},{"month":2,"day":8,"text":"第1回日劇ウエスタンカーニバル開幕。"},{"month":2,"day":14,"text":"イラクとヨルダンによる連邦国家、アラブ連邦発足。"},{"month":2,"day":16,"text":"滄浪号ハイジャック事件。"},{"month":3,"day":1,"text":"ラジオ九州テレビ（現在のRKB毎日放送テレビ）が放送開始。"},{"month":3,"day":9,"text":"関門トンネルが開通。本州（山口県下関市）と九州（福岡県門司市、現在の北九州市門司区）が道路で結ばれる。"},{"month":3,"day":17,"text":"国際海事機関発足。"},{"month":3,"day":24,"text":"エルヴィス・プレスリーがアメリカ合衆国陸軍に入隊。"},{"month":3,"day":26,"text":"ナンシー梅木が日本人初のアカデミー助演女優賞を受賞。"},{"month":3,"day":27,"text":"ニキータ・フルシチョフがソビエト連邦の首相に就任。"},{"month":4,"day":5,"text":"巨人・長嶋茂雄選手、4打席4三振デビュー。"},{"month":4,"day":17,"text":"ブリュッセル万国博覧会開幕。（ - 10月19日）"},{"month":4,"day":19,"text":"日本コカ・コーラ、炭酸飲料「ファンタ」を日本で発売。"},{"month":4,"day":25,"text":"衆議院解散（話し合い解散）。"},{"month":5,"day":2,"text":"長崎国旗事件"},{"month":5,"day":5,"text":"多摩動物公園開園"},{"month":5,"day":5,"text":"広島市の広島平和記念公園内で、原爆症で死亡した佐々木禎子を追悼する「原爆の子の像」の除幕式。"},{"month":5,"day":12,"text":"アメリカ合衆国とカナダが北アメリカ航空宇宙防衛司令部設置について正式合意。"},{"month":5,"day":22,"text":"第28回衆議院議員総選挙投票。"},{"month":5,"day":24,"text":"旧・国立競技場で、第3回アジア競技大会が開催。"},{"month":5,"day":31,"text":"大阪市営地下鉄四つ橋線（現・Osaka Metro四つ橋線）の岸里駅 - 玉出駅間が開業。"},{"month":6,"day":1,"text":"新日本放送（NJB）が毎日放送（MBS）に社名変更。"},{"month":6,"day":1,"text":"山陽放送テレビが放送開始。"},{"month":6,"day":1,"text":"大阪テレビ放送（現在の朝日放送テ