{"year":1903,"events":[{"month":1,"day":1,"text":"英国王エドワード7世がインド皇帝に即位"},{"month":1,"day":14,"text":"大谷光瑞率いる大谷探検隊がインドビハール州ラージギル郊外で釈迦の住んだ霊鷲山を発見。"},{"month":1,"day":23,"text":"夏目漱石が、文部省留学生としての英国留学から帰国。"},{"month":2,"day":1,"text":"中央本線笹子トンネル開通"},{"month":2,"day":3,"text":"アメリア・サックとアニー・ウォルターズが絞首刑に科される"},{"month":3,"day":18,"text":"宇高連絡船運航開始"},{"month":4,"day":13,"text":"日本で小学校令が改正され国定教科書制度が取り入れられる。"},{"month":4,"day":18,"text":"逗子開成中学校・高等学校が開校"},{"month":5,"day":1,"text":"4日 - イギリス国王エドワード7世がパリ公式訪問。これを機に英仏関係緊密化。"},{"month":5,"day":8,"text":"第18特別議会召集。"},{"month":5,"day":22,"text":"第一高等学校生徒・藤村操が華厳滝で自殺。社会に大きな影響を与える。"},{"month":6,"day":1,"text":"日比谷公園が開園する。"},{"month":6,"day":10,"text":"セルビアで国王アレクサンダル1世・オブレノヴィチと王妃ドラガがクーデターにより暗殺される。"},{"month":6,"day":10,"text":"同日付で七博士意見書が時の大日本帝国首相・桂太郎や外務大臣・小村寿太郎等に提出される。"},{"month":6,"day":16,"text":"米国でフォード・モーターが設立される。"},{"month":7,"day":1,"text":"第1回大会ツール・ド・フランス開催（ - 7月19日）"},{"month":7,"day":14,"text":"西園寺公望が立憲政友会総裁に就任"},{"month":8,"day":4,"text":"ピウス10世がローマ教皇に就任"},{"month":8,"day":10,"text":"パリメトロ火災発生、84名が犠牲となる。"},{"month":8,"day":20,"text":"ブルガリア人組織内部マケドニア革命組織、を実行。マケドニア闘争開始。"},{"month":9,"day":12,"text":"日本初の市電である大阪市の大阪市電が開業。"},{"month":9,"day":20,"text":"京都市で二井商会が日本初の営業バスを開業（バスの日）"},{"month":10,"day":1,"text":"浅草に電気館設立（日本初の映画常設館）"},{"month":10,"day":4,"text":"未明にウィーンの黒いスペイン館で、オットー・ヴァイニンガーが23歳でピストル自殺。遺作「性と性格」がベストセラーになる。"},{"month":10,"day":6,"text":"小村寿太郎らによって日露交渉が開始される。"},{"month":10,"day":13,"text":"現行メジャーリーグの第一回ワールドシリーズで、ボストン・アメリカンズ（のちレッドソックス）が優勝。"},{"month":11,"day":3,"text":"パナマ共和国が米国の援助により、コロンビアから分離独立する。"},{"month":11,"day":15,"text":"幸徳秋水らが平民社を設立。「平民新聞」を創刊。"},{"month":11,"day":17,"text":"ロシア社会民主労働党がボリシェビキとメンシェビキに分裂"},{"month":11,"day":18,"text":"パナマ運河条約調印（米国がパナマ運河地帯の永久租借権を獲得）"},{"month":11,"day":21,"text":"第1回早慶戦"},{"month":12,"day":5,"text":"第19議会召集"},{"month":12,"day":17,"text":"ライト兄弟が人類初の動力飛行に成功"}],"highlights":[],"chartWeeks":[],"prevYearLast":null,"people":[{"name":"香淳皇后","month":3,"day":6,"desc":"昭和天皇の皇后","photo":"https://