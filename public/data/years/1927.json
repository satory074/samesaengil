{"year":1927,"events":[{"month":1,"day":4,"text":"武漢の民衆が漢口英租界を占領"},{"month":1,"day":8,"text":"日本水平社結成"},{"month":1,"day":11,"text":"米海軍がグアム島駐在の陸戦隊3百名を支那に急派"},{"month":1,"day":17,"text":"日本ゼネラル・モータース設立"},{"month":1,"day":19,"text":"英政府が支那派兵を決定"},{"month":1,"day":19,"text":"前年12月に没した日本の大行天皇の追号が大正天皇と決まる"},{"month":1,"day":20,"text":"憲政会・立憲政友会・政友本党の3党首会談で解散回避"},{"month":1,"day":20,"text":"春秋社「世界大思想全集」創刊"},{"month":1,"day":23,"text":"及川奥郎が新しい小惑星を発見"},{"month":1,"day":24,"text":"東京地方で気象台開設以来の寒波、ー8.6度の気温により、各所で水道管破裂する"},{"month":1,"day":25,"text":"明治節（現文化の日）制定を可決（1927年は“明治60年”）"},{"month":1,"day":28,"text":"宮崎県小林町で大火（1200棟焼失）"},{"month":2,"day":7,"text":"大正天皇大喪。大赦137,669名、減刑46,138名。"},{"month":2,"day":9,"text":"争議中の磐代炭坑労働組合員が右翼暴力団と衝突"},{"month":2,"day":12,"text":"英支那派遣軍が上海に上陸"},{"month":2,"day":14,"text":"昭和2年豪雪により、伊吹山（滋賀県）で11m82cmの積雪を記録。"},{"month":2,"day":24,"text":"日本放送協会が初めてオペラを放送（カヴァレリア・ルスティカーナ）"},{"month":3,"day":1,"text":"東京帝大法学部に設立された明治新聞雑誌文庫の業務開始（事務主任は宮武外骨）"},{"month":3,"day":3,"text":"アメリカから贈られた青い目の人形の歓迎会が各地で始まる。"},{"month":3,"day":7,"text":"北丹後地震"},{"month":3,"day":8,"text":"火災保険会社が北丹後地震に対する保険不払を声明"},{"month":3,"day":9,"text":"金華山沖で鹿児島商船水産学校の練習船「霧島丸」が沈没（43名死亡）"},{"month":3,"day":10,"text":"三菱信託株式会社（後の三菱信託銀行）設立"},{"month":3,"day":14,"text":"片岡直温蔵相が「東京渡辺銀行が破綻」と失言（昭和金融恐慌の発端）"},{"month":3,"day":15,"text":"東京渡辺銀行が、姉妹行である「あかぢ貯蓄銀行」ともども休業。京浜地方で銀行取り付け騒ぎ。"},{"month":3,"day":19,"text":"中井銀行休業（合併・買収など曲折を経て、現 みずほ銀行となっている）"},{"month":3,"day":21,"text":"日本銀行が市中銀行に対して非常貸出しを実施"},{"month":3,"day":22,"text":"村井銀行・中沢銀行・八十四銀行など諸銀行が休業（多くが合併・買収など曲折を経て、現 みずほ銀行となっている）"},{"month":3,"day":24,"text":"蔣介石の国民革命軍が南京入城の際、諸外国領事館を襲撃（南京事件）"},{"month":3,"day":28,"text":"矢田上海総領事が南京事件につき蔣介石に抗議"},{"month":3,"day":29,"text":"南京総領事館の荒木海軍大尉が自決"},{"month":3,"day":31,"text":"村山貯水池（多摩湖）完成"},{"month":4,"day":2,"text":"鈴木商店破産"},{"month":4,"day":4,"text":"海軍航空本部令公布"},{"month":4,"day":5,"text":"花柳病予防法公布"},{"month":4,"day":8,"text":"第六十五銀行休業 - 株式相場大暴落"},{"month":4,"day":16,"text":"重巡妙高が横須賀で進水"},{"month":4,"day"