---
import "../styles/globals.css";
import { absUrl, siteLink } from "@/lib/url";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "samesaengil — 同じ誕生日、なにがある？",
  description = "生年月日を入れるだけ。同じ誕生日の有名人・キャラ・記念日・星座まで、あなたの誕生日まるわかり。飲み会のネタにどうぞ。",
} = Astro.props;

const ogImage = absUrl("/favicon.svg");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={siteLink("/favicon.svg")} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <div class="wrap">
      <header class="site-header">
        <a href={siteLink("/")} class="logo">🎂 samesaengil</a>
        <p class="tagline">生年月日を入れると、同じ誕生日のあれこれが出てくるよ</p>
      </header>

      <slot />

      <footer class="site-footer">
        <p>
          出典: <a href="https://www.wikipedia.org/" target="_blank" rel="noopener">Wikipedia</a> ／
          <a href="https://www.wikidata.org/" target="_blank" rel="noopener">Wikidata</a> ／
          <a href="https://commons.wikimedia.org/" target="_blank" rel="noopener">Wikimedia Commons</a>
        </p>
        <p>
          有名人の顔写真は Wikimedia Commons（自由ライセンス）より。フィクションキャラは名前と作品名のみ掲載しています。
        </p>
        <p>© samesaengil — 誕生日を知るための非公式サイト</p>
      </footer>
    </div>
  </body>
</html>
