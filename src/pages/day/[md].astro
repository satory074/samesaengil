---
// 日別ページ（月日だけで決まる情報）を 366 ページ静的生成する＝検索流入の受け皿。
// 年に依存する情報（年齢・生まれた年）はここでは出さず、年フォームからトップ（?d=）へ送る。
//
// 本文は src/app/render.ts の文字列ビルダをそのまま呼ぶ（DOM 非依存なのでサーバ側でも動く）。
// 実装を二重に持たないための要。render.ts は全データを esc() 済み ＝ set:html でも安全。
import fs from "node:fs";
import path from "node:path";
import Layout from "@/components/Layout.astro";
import { allDays, dayKeyOf, dayLabel, parseDayKey } from "@/lib/days";
import type { DayData } from "@/lib/types";
import { anniversaryHtml, animalsHtml, charactersHtml, peopleHtml } from "@/app/render";

export function getStaticPaths() {
  return allDays().map((md) => ({ params: { md: dayKeyOf(md) } }));
}

const { md: key } = Astro.params;
const parsed = parseDayKey(key!)!;

// 31MB ぶんを import.meta.glob でビルドグラフに載せない（必要な 1 ファイルだけ読む）。
const file = path.join(process.cwd(), "public", "data", "days", `${key}.json`);
const day = JSON.parse(fs.readFileSync(file, "utf8")) as DayData;

const label = dayLabel(parsed);
const title = `${label}生まれの有名人・キャラ・記念日 ｜ samesaengil`;
const description = `${label}生まれの有名人${day.people.length}人、同じ誕生日のフィクションキャラ${day.characters.length}件、${label}の記念日・できごとをまとめました。`;

const currentYear = new Date().getFullYear();
const years = Array.from({ length: currentYear - 1900 + 1 }, (_, i) => currentYear - i);

const body =
  peopleHtml(day.people) +
  animalsHtml(day.animals) +
  charactersHtml(day.characters) +
  anniversaryHtml(day.anniversaries, day.events);
---

<Layout title={title} description={description} canonical={`/day/${key}/`}>
  <main id="day" data-key={key}>
    <h1 class="date-big"><em>{label}</em>生まれ</h1>

    <form class="bday-form" id="year-form" autocomplete="off">
      <label class="label" for="in-year">生まれた年を入れると、年齢・干支・その年の出来事も出ます🎈</label>
      <div class="row">
        <div class="field">
          <span>年</span>
          <select id="in-year" aria-label="年">
            {years.map((y) => <option value={y} selected={y === 2000}>{y}</option>)}
          </select>
        </div>
      </div>
      <div class="go-row">
        <button class="btn" type="submit">🎉 {label}生まれの詳しい結果を見る</button>
      </div>
    </form>

    <div set:html={body} />
  </main>

  <script>
    import { bootDay } from "../../app/day";
    const root = document.getElementById("day")!;
    bootDay(root, root.dataset.key!);
  </script>
</Layout>
